# ── Anthropic ─────────────────────────────────────────────────────────
# Used for: agent runtime, LLM-as-judge in retrieval reranker and eval
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (defaults below are sensible)
ANTHROPIC_AGENT_MODEL=claude-sonnet-4-6
ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5

# ── OpenAI (embeddings only) ──────────────────────────────────────────
# Tradeoff: Voyage voyage-3-large would be the Anthropic-recommended
# production choice. OpenAI here for setup speed + cost. See README.
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon key only used if you wire JWT auth into the API later — not
# required for the assessment.
SUPABASE_ANON_KEY=eyJ...

# ── Retrieval tuning ──────────────────────────────────────────────────
RAG_MATCH_COUNT=8
KB_HIGH_CONFIDENCE_SIM=0.78

# ── API ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
