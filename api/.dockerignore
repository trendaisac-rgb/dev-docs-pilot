# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/

# Caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs (image rebuilds its own)
.venv/
venv/

# Local-only ingest artifacts (regenerated)
.ingest_cache/

# Eval outputs (committed via report.md only — runs/ is local)
eval/runs/

# Env / secrets — these go via `fly secrets set`
.env
.env.*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test scaffolding not needed at runtime
tests/

# Docs (the image doesn't serve them)
docs/

# Lockfiles / version pins
.python-version
uv.lock

# Local sync of source from local-only paths
*.log
